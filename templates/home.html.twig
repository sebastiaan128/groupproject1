{% extends 'base.html.twig' %}
{% block title %}Home — TribeChat{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">

    <div class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white">
            Welcome back, <span class="text-indigo-600 dark:text-indigo-400">{{ user_name|split(' ')|first|capitalize }}</span>
        </h1>
        <p class="mt-2 text-gray-500 dark:text-gray-400 text-base">Here's what's happening in your TribeChat community.</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-10">
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl p-5 shadow-sm">
            <p class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide font-medium mb-1">Students</p>
            <p class="text-3xl font-bold text-indigo-600 dark:text-indigo-400">{{ total_students }}</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">registered on platform</p>
        </div>
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl p-5 shadow-sm">
            <p class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide font-medium mb-1">Questions</p>
            <p class="text-3xl font-bold text-indigo-600 dark:text-indigo-400">{{ total_vragen }}</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">asked by the community</p>
        </div>
        <div class="col-span-2 sm:col-span-1 bg-gradient-to-br from-indigo-500 to-violet-600 rounded-2xl p-5 shadow-sm text-white">
            <p class="text-xs text-indigo-200 uppercase tracking-wide font-medium mb-1">Your Tribe</p>
            <p class="text-3xl font-bold">HBO-ICT</p>
            <p class="text-xs text-indigo-200 mt-1">Connect with classmates</p>
        </div>
    </div>

    {% if mijn_profiel %}
    <h2 class="text-lg font-semibold text-gray-700 dark:text-gray-300 mb-4">Your Stats</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl p-5 shadow-sm text-center">
            <p class="text-2xl font-bold text-violet-600 dark:text-violet-400">{{ mijn_profiel.vragen|length }}</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Questions asked</p>
        </div>
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl p-5 shadow-sm text-center">
            <p class="text-2xl font-bold text-green-600 dark:text-green-400">{{ mijn_profiel.antwoorden|length }}</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Answers given</p>
        </div>
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl p-5 shadow-sm text-center">
            <p class="text-2xl font-bold text-yellow-500 dark:text-yellow-400">{{ mijn_punten }}</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Leaderboard points</p>
        </div>
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl p-5 shadow-sm text-center">
            <p class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">{% if mijn_rank %}#{{ mijn_rank }}{% else %}—{% endif %}</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Your rank</p>
        </div>
    </div>
    {% endif %}



    <div class="gap-6 mb-10">

        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 dark:border-gray-700">
                <h2 class="font-semibold text-gray-800 dark:text-white text-sm">Recent Questions</h2>
                <a href="{{ path('questions') }}" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline">View all →</a>
            </div>
            <ul class="divide-y divide-gray-100 dark:divide-gray-700">
                {% for vraag in recente_vragen %}
                <li>
                    <a href="{{ path('anwser-question', {id: vraag.id}) }}" class="flex items-center gap-3 px-5 py-3 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group">
                        <span class="shrink-0 w-2 h-2 rounded-full {% if vraag.status == 'Open' %}bg-green-400{% else %}bg-red-400{% endif %}"></span>
                        <div class="min-w-0 flex-1">
                            <p class="text-sm font-medium text-gray-800 dark:text-gray-100 truncate">{{ vraag.titel }}</p>
                            <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">
                                {{ vraag.antwoorden|length }} answer{{ vraag.antwoorden|length != 1 ? 's' : '' }}
                                · {{ vraag.upvotes ?? 0 }} votes
                            </p>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" class="shrink-0 w-4 h-4 text-gray-300 dark:text-gray-600 group-hover:text-indigo-500 dark:group-hover:text-indigo-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"/>
                        </svg>
                    </a>
                </li>
                {% else %}
                <li class="px-5 py-6 text-center text-sm text-gray-400 dark:text-gray-500">No questions yet.</li>
                {% endfor %}
            </ul>
        </div>


    </div>

    <div class="bg-gradient-to-r from-indigo-500/10 to-violet-500/10 dark:from-indigo-500/20 dark:to-violet-500/20 border border-indigo-200 dark:border-indigo-500/30 rounded-2xl p-6 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
            <p class="font-semibold text-gray-900 dark:text-white">Complete your profile</p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Add your bio, study and interests so classmates can find you.</p>
        </div>
        <a href="{{ path('profile') }}" class="shrink-0 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-all">
            Go to Profile →
        </a>
    </div>

</div>
{% endblock %}
