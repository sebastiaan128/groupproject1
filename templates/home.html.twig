{% extends 'base.html.twig' %}
{% block title %}Home — TribeChat{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">

    <div class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white">
            Welcome back, <span class="text-indigo-600 dark:text-indigo-400">{{ user_name|split(' ')|first|capitalize }}</span>
        </h1>
        <p class="mt-2 text-gray-500 dark:text-gray-400 text-base">Here's what's happening in your TribeChat community.</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-10">
        <div class="bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-2xl p-5 shadow-sm">
            <p class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide font-medium mb-1">Students</p>
            <p class="text-3xl font-bold text-indigo-600 dark:text-indigo-400">{{ total_students }}</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">registered on platform</p>
        </div>
        <div class="bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-2xl p-5 shadow-sm">
            <p class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide font-medium mb-1">Questions</p>
            <p class="text-3xl font-bold text-indigo-600 dark:text-indigo-400">{{ total_vragen }}</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">asked by the community</p>
        </div>
        <div class="col-span-2 sm:col-span-1 bg-gradient-to-br from-indigo-500 to-violet-600 rounded-2xl p-5 shadow-sm text-white">
            <p class="text-xs text-indigo-200 uppercase tracking-wide font-medium mb-1">Your Tribe</p>
            <p class="text-3xl font-bold">HBO-ICT</p>
            <p class="text-xs text-indigo-200 mt-1">Connect with classmates</p>
        </div>
    </div>

    <h2 class="text-lg font-semibold text-gray-700 dark:text-gray-300 mb-4">Quick Actions</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">

        <a href="{{ path('network') }}" class="group bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-2xl p-6 shadow-sm hover:shadow-md hover:border-indigo-300 dark:hover:border-indigo-500/50 transition-all duration-200">
            <div class="w-11 h-11 rounded-xl bg-indigo-100 dark:bg-indigo-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-600 dark:text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
            </div>
            <h3 class="font-semibold text-gray-900 dark:text-white mb-1">Network</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">Browse and connect with fellow students.</p>
        </a>

        <a href="{{ path('questions') }}" class="group bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-2xl p-6 shadow-sm hover:shadow-md hover:border-indigo-300 dark:hover:border-indigo-500/50 transition-all duration-200">
            <div class="w-11 h-11 rounded-xl bg-violet-100 dark:bg-violet-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-violet-600 dark:text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </div>
            <h3 class="font-semibold text-gray-900 dark:text-white mb-1">Questions</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">Ask questions and help your peers.</p>
        </a>

        <a href="{{ path('profile') }}" class="group bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-2xl p-6 shadow-sm hover:shadow-md hover:border-indigo-300 dark:hover:border-indigo-500/50 transition-all duration-200">
            <div class="w-11 h-11 rounded-xl bg-pink-100 dark:bg-pink-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pink-600 dark:text-pink-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                </svg>
            </div>
            <h3 class="font-semibold text-gray-900 dark:text-white mb-1">Your Profile</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">Update your info, bio and interests.</p>
        </a>

    </div>

    <div class="bg-gradient-to-r from-indigo-500/10 to-violet-500/10 dark:from-indigo-500/20 dark:to-violet-500/20 border border-indigo-200 dark:border-indigo-500/30 rounded-2xl p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
            <h3 class="font-semibold text-gray-900 dark:text-white mb-1">Complete your profile</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">Add your bio, study and interests so classmates can find you.</p>
        </div>
        <a href="{{ path('profile') }}" class="shrink-0 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-all">
            Go to Profile →
        </a>
    </div>

</div>
{% endblock %}
