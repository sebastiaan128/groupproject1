{% extends 'base.html.twig' %}
{% block title %}Home — TribeChat{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 flex flex-col gap-6">

    <div class="relative bg-gradient-to-br from-indigo-600 to-violet-600 rounded-2xl p-6 sm:p-8 overflow-hidden shadow-sm">
        <div class="absolute inset-0 opacity-10" style="background-image:radial-gradient(circle at 80% 20%, white 0%, transparent 60%)"></div>
        <div class="relative flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
            <div>
                <p class="text-indigo-200 text-sm font-medium mb-1">HBO-ICT · TribeChat</p>
                <h1 class="text-2xl sm:text-3xl font-bold text-white leading-snug">
                    Welcome back, {{ user_name|split(' ')|first|capitalize }}
                </h1>
                <p class="mt-1 text-indigo-200 text-sm">Here's what's happening in your community.</p>
            </div>
            <div class="flex gap-4 shrink-0">
                <div class="text-center">
                    <p class="text-2xl font-bold text-white">{{ total_students }}</p>
                    <p class="text-xs text-indigo-200 mt-0.5">Students</p>
                </div>
                <div class="w-px bg-white/20"></div>
                <div class="text-center">
                    <p class="text-2xl font-bold text-white">{{ total_vragen }}</p>
                    <p class="text-xs text-indigo-200 mt-0.5">Questions</p>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">

        <div class="lg:col-span-2 flex flex-col gap-6">

            <div class="relative bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 dark:border-gray-700">
                    <h2 class="font-semibold text-gray-800 dark:text-white text-sm">Your Stats</h2>
                </div>
                <div class="grid grid-cols-2 divide-x divide-y divide-gray-100 dark:divide-gray-700">
                    <div class="p-5 text-center">
                        <p class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">{{ is_guest ? '?' : mijn_profiel.vragen|length }}</p>
                        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Questions asked</p>
                    </div>
                    <div class="p-5 text-center">
                        <p class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">{{ is_guest ? '?' : mijn_profiel.antwoorden|length }}</p>
                        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Answers given</p>
                    </div>
                    <div class="p-5 text-center">
                        <p class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">{{ is_guest ? '?' : mijn_punten }}</p>
                        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Leaderboard points</p>
                    </div>
                    <div class="p-5 text-center">
                        <p class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">{{ is_guest ? '?' : (mijn_rank ? '#' ~ mijn_rank : '—') }}</p>
                        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Your rank</p>
                    </div>
                </div>
                {% if is_guest %}
                <div class="absolute inset-0 backdrop-blur-sm bg-white/30 dark:bg-gray-800/30 flex flex-col items-center justify-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <a href="{{ path('login') }}" class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 hover:underline">Log in to see your stats</a>
                </div>
                {% endif %}
            </div>

            <div class="bg-gradient-to-r from-indigo-500/10 to-violet-500/10 dark:from-indigo-500/20 dark:to-violet-500/20 border border-indigo-200 dark:border-indigo-500/30 rounded-2xl p-5 flex flex-col gap-3">
                <div>
                    <p class="font-semibold text-gray-900 dark:text-white text-sm">Complete your profile</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Add your bio, study and interests so classmates can find you.</p>
                </div>
                <a href="{{ path('profile') }}" class="self-start bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-semibold px-4 py-2 rounded-xl transition-colors">
                    Go to Profile →
                </a>
            </div>

        </div>

        <div class="lg:col-span-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 dark:border-gray-700">
                <h2 class="font-semibold text-gray-800 dark:text-white text-sm">Recent Questions</h2>
                <a href="{{ path('questions') }}" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline">View all →</a>
            </div>
            <ul class="divide-y divide-gray-100 dark:divide-gray-700">
                {% for vraag in recente_vragen %}
                <li>
                    <a href="{{ path('anwser-question', {id: vraag.id}) }}" class="flex items-center gap-3 px-5 py-3 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group">
                        <span class="shrink-0 w-2 h-2 rounded-full {% if vraag.status == 'Open' %}bg-green-400{% else %}bg-red-400{% endif %}"></span>
                        <div class="min-w-0 flex-1">
                            <p class="text-sm font-medium text-gray-800 dark:text-gray-100 truncate">{{ vraag.titel }}</p>
                            <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">
                                {{ vraag.antwoorden|length }} answer{{ vraag.antwoorden|length != 1 ? 's' : '' }}
                                · {{ vraag.upvotes ?? 0 }} votes
                            </p>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" class="shrink-0 w-4 h-4 text-gray-300 dark:text-gray-600 group-hover:text-indigo-500 dark:group-hover:text-indigo-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"/>
                        </svg>
                    </a>
                </li>
                {% else %}
                <li class="px-5 py-6 text-center text-sm text-gray-400 dark:text-gray-500">No questions yet.</li>
                {% endfor %}
            </ul>
        </div>

    </div>

</div>
{% endblock %}
