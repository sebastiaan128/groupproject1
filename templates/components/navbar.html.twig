{% set route = app.request.attributes.get('_route') %}

<div class="navbar-wrapper flex justify-center px-4 sm:px-6 py-4">
    <nav class="navbar-glass relative flex items-center justify-between rounded-full px-3 py-3 w-full min-h-[64px]">

        <a href="{{ path('home') }}" class="shrink-0 pl-1">
            <img src="/assets/logo/Logo_Dark.png" alt="TribeChat" class="w-[200px] h-auto dark:hidden hidden sm:block">
            <img src="/assets/logo/Logo_Light.png" alt="TribeChat" class="hidden dark:sm:block w-[200px] h-auto">
            <img src="/assets/logo/Logo_Dark.png" alt="TribeChat" class="h-12 w-auto dark:hidden sm:hidden">
            <img src="/assets/logo/Logo_Light.png" alt="TribeChat" class="hidden dark:block dark:sm:hidden h-12 w-auto">
        </a>
        <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 flex items-center">
            <ul class="hidden sm:flex items-center gap-1 text-sm font-medium">
                <li>
                    <a href="{{ path('home') }}" class="px-4 py-1.5 transition-all flex flex-col items-center {% if route == 'home' %}text-gray-900 dark:text-white{% else %}text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400{% endif %}">
                        <span>Home</span>
                        {% if route == 'home' %}<span class="block h-[1.5px] w-full bg-indigo-500 rounded-full mt-0.5"></span>{% endif %}
                    </a>
                </li>
                <li>
                    <a href="{{ path('network') }}" class="px-4 py-1.5 transition-all flex flex-col items-center {% if route == 'network' %}text-gray-900 dark:text-white{% else %}text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400{% endif %}">
                        <span>Network</span>
                        {% if route == 'network' %}<span class="block h-[1.5px] w-full bg-indigo-500 rounded-full mt-0.5"></span>{% endif %}
                    </a>
                </li>
                <li>
                    <a href="{{ path('questions') }}" class="px-4 py-1.5 transition-all flex flex-col items-center {% if route == 'questions' %}text-gray-900 dark:text-white{% else %}text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400{% endif %}">
                        <span>Questions</span>
                        {% if route == 'questions' %}<span class="block h-[1.5px] w-full bg-indigo-500 rounded-full mt-0.5"></span>{% endif %}
                    </a>
                </li>
                <li>
                    <a href="{{ path('leaderboard') }}" class="px-4 py-1.5 transition-all flex flex-col items-center {% if route == 'leaderboard' %}text-gray-900 dark:text-white{% else %}text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400{% endif %}">
                        <span>Leaderboard</span>
                        {% if route == 'leaderboard' %}<span class="block h-[1.5px] w-full bg-indigo-500 rounded-full mt-0.5"></span>{% endif %}
                    </a>
                </li>
            </ul>
        </div>

        <div class="flex items-center gap-2 shrink-0">
            <button id="theme-toggle" aria-label="Toggle dark mode" class="theme-pill-toggle">
                <span class="theme-pill-thumb">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                </span>
            </button>

            <div class="relative hidden sm:block">
                <button id="profile-btn" class="profile-pill-btn mr-3.75" aria-expanded="false">
                    <span class="w-8 h-8 rounded-full overflow-hidden shrink-0">
                        <img id="desktop-avatar" src="/assets/logo/profile.png" alt="User Avatar" class="w-full h-full object-cover">
                    </span>
                    <span class="text-sm font-medium text-gray-800 dark:text-gray-100 truncate">
                        {{ app.session.get('user_name')|split(' ')|first|capitalize }}
                    </span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-500 dark:text-gray-400 shrink-0 transition-transform duration-200" id="profile-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>
                <div id="profile-dropdown" class="hidden absolute right-0 top-full mt-2 bg-white dark:bg-gray-900 border border-gray-200 dark:border-white/10 shadow-xl rounded-2xl px-2 py-2 flex flex-col gap-0.5 text-sm min-w-[160px] z-50">
                    <a href="{{ path('profile') }}" class="flex items-center gap-2 px-3 py-2 rounded-xl text-gray-700 dark:text-gray-200 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                        Profile
                    </a>
                    <div class="border-t border-gray-200 dark:border-white/10 my-1"></div>
                    <a href="{{ path('logout') }}" class="flex items-center gap-2 px-3 py-2 rounded-xl text-red-500 hover:text-red-600 dark:hover:text-red-400 transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Logout
                    </a>
                </div>
            </div>

            <button id="nav-hamburger" class="sm:hidden theme-toggle-btn" aria-label="Open menu" aria-expanded="false">
                <svg id="ham-open" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-700 dark:text-gray-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
                <svg id="ham-close" xmlns="http://www.w3.org/2000/svg" class="hidden w-4 h-4 text-gray-700 dark:text-gray-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

    </nav>

    <div id="mobile-menu" class="sm:hidden hidden absolute top-full left-4 right-4 sm:left-6 sm:right-6 mt-2 navbar-glass rounded-2xl px-4 py-3 flex flex-col gap-1 text-sm font-medium text-gray-700 dark:text-gray-200">
        <a href="{{ path('home') }}" class="px-4 py-2 rounded-xl transition-all {% if route == 'home' %}text-indigo-600 dark:text-indigo-400 font-semibold{% else %}hover:text-indigo-600 dark:hover:text-indigo-400{% endif %}">Home</a>
        <a href="{{ path('network') }}" class="px-4 py-2 rounded-xl transition-all {% if route == 'network' %}text-indigo-600 dark:text-indigo-400 font-semibold{% else %}hover:text-indigo-600 dark:hover:text-indigo-400{% endif %}">Network</a>
        <a href="{{ path('questions') }}" class="px-4 py-2 rounded-xl transition-all {% if route == 'questions' %}text-indigo-600 dark:text-indigo-400 font-semibold{% else %}hover:text-indigo-600 dark:hover:text-indigo-400{% endif %}">Questions</a>
        <a href="{{ path('leaderboard') }}" class="px-4 py-2 rounded-xl transition-all {% if route == 'leaderboard' %}text-indigo-600 dark:text-indigo-400 font-semibold{% else %}hover:text-indigo-600 dark:hover:text-indigo-400{% endif %}">Leaderboard</a>
        <div class="border-t border-gray-200 dark:border-white/10 mt-1 pt-2 flex items-center justify-between">
            <a href="{{ path('profile') }}" class="flex items-center gap-2 px-4 py-2 rounded-xl transition-all hover:text-indigo-600 dark:hover:text-indigo-400">
                <div class="avatar-glass w-7 h-7 rounded-full overflow-hidden flex items-center justify-center text-xs font-semibold text-gray-700 dark:text-gray-200">
                    <img id="mobile-avatar" src="" alt="User Avatar" class="w-full h-full object-cover">
                </div>
                <span class="text-gray-600 dark:text-gray-300">{{ app.session.get('user_name')|split(' ')|first|capitalize }}</span>
            </a>
            <a href="{{ path('logout') }}" class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-red-500 hover:text-red-600 dark:hover:text-red-400 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Logout
            </a>
        </div>
    </div>
</div>

<script>
    (function () {
        var btn    = document.getElementById('nav-hamburger');
        var menu   = document.getElementById('mobile-menu');
        var open   = document.getElementById('ham-open');
        var close  = document.getElementById('ham-close');

        var desktopAvatar = document.getElementById('desktop-avatar');
        var mobileAvatar  = document.getElementById('mobile-avatar');
        if (desktopAvatar && mobileAvatar) {
            mobileAvatar.src = desktopAvatar.src;
            mobileAvatar.alt = desktopAvatar.alt;
        }

        if (btn) {
            btn.addEventListener('click', function () {
                var expanded = btn.getAttribute('aria-expanded') === 'true';
                btn.setAttribute('aria-expanded', String(!expanded));
                menu.classList.toggle('hidden');
                open.classList.toggle('hidden');
                close.classList.toggle('hidden');
            });
        }

        var profileBtn      = document.getElementById('profile-btn');
        var profileDropdown = document.getElementById('profile-dropdown');
        var profileChevron  = document.getElementById('profile-chevron');

        if (profileBtn && profileDropdown) {
            profileBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                var isOpen = !profileDropdown.classList.contains('hidden');
                profileDropdown.classList.toggle('hidden');
                profileBtn.setAttribute('aria-expanded', String(!isOpen));
                if (profileChevron) profileChevron.style.transform = isOpen ? '' : 'rotate(180deg)';
            });
        }

        document.addEventListener('click', function (e) {
            if (btn && !btn.contains(e.target) && menu && !menu.contains(e.target)) {
                btn.setAttribute('aria-expanded', 'false');
                if (menu) menu.classList.add('hidden');
                if (open) open.classList.remove('hidden');
                if (close) close.classList.add('hidden');
            }
            if (profileBtn && !profileBtn.contains(e.target)) {
                if (profileDropdown) profileDropdown.classList.add('hidden');
                if (profileBtn) profileBtn.setAttribute('aria-expanded', 'false');
                if (profileChevron) profileChevron.style.transform = '';
            }
        });
    })();
</script>
