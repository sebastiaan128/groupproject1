<div class="border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 rounded-2xl p-4 mb-3 flex flex-col sm:flex-row gap-4 shadow-sm hover:shadow-md transition-shadow duration-200">

    {# Stats column #}
    <div class="flex sm:flex-col gap-2 sm:gap-3 sm:w-24 shrink-0">
        <div class="bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 border border-blue-300 dark:border-blue-700 rounded-xl py-2 px-3 flex flex-col items-center text-sm font-semibold w-full">
            <span class="text-xs font-normal opacity-70">Votes</span>
            <span>4</span>
        </div>
        <div class="bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300 border border-green-300 dark:border-green-700 rounded-xl py-2 px-3 flex flex-col items-center text-sm font-semibold w-full">
            <span class="text-xs font-normal opacity-70">Answers</span>
            <span>2</span>
        </div>
        <div class="bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300 border border-purple-300 dark:border-purple-700 rounded-xl py-2 px-3 flex flex-col items-center text-sm font-semibold w-full">
            <span class="text-xs font-normal opacity-70">Views</span>
            <span>24</span>
        </div>
    </div>

    {# Content column #}
    <div class="flex-1 flex flex-col justify-between gap-3 min-w-0">
        <h2 class="font-semibold text-gray-900 dark:text-gray-100 text-lg leading-snug">
            Question title goes here
        </h2>

        <div class="flex flex-wrap gap-2">
            <span class="bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 rounded-lg py-0.5 px-2 text-sm">React</span>
            <span class="bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-300 rounded-lg py-0.5 px-2 text-sm">Javascript</span>
            <span class="bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300 rounded-lg py-0.5 px-2 text-sm">SQL</span>
        </div>
    </div>

    {# Status badge #}
    <div class="shrink-0 self-start sm:self-center">
        <span class="bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300 border border-green-300 dark:border-green-700 rounded-xl py-1 px-3 text-sm font-semibold whitespace-nowrap">
            Answered
        </span>
    </div>
</div>
