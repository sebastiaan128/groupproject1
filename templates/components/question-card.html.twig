<a href="{{ path('anwser-question', { id: vraag.id }) }}"
    class="group border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 rounded-2xl p-4 mb-3 flex flex-col sm:flex-row gap-4 shadow-sm hover:shadow-md hover:border-indigo-300 dark:hover:border-indigo-600 transition-all duration-200 cursor-pointer block">

    <div class="flex sm:flex-col gap-2 sm:gap-3 sm:w-20 shrink-0 text-center">
        <div class="bg-gray-50 dark:bg-gray-700/60 border border-gray-200 dark:border-gray-600 rounded-xl py-2 px-3 flex flex-col items-center w-full">
            <span class="text-base font-bold text-blue-600 dark:text-blue-400">{{ vraag.upvotes }}</span>
            <span class="text-xs text-gray-400 dark:text-gray-500">votes</span>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/60 border border-gray-200 dark:border-gray-600 rounded-xl py-2 px-3 flex flex-col items-center w-full">
            <span class="text-base font-bold text-emerald-600 dark:text-emerald-400">{{ vraag.antwoorden|length }}</span>
            <span class="text-xs text-gray-400 dark:text-gray-500">answers</span>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/60 border border-gray-200 dark:border-gray-600 rounded-xl py-2 px-3 flex flex-col items-center w-full">
            <span class="text-base font-bold text-gray-500 dark:text-gray-400">{{ vraag.views }}</span>
            <span class="text-xs text-gray-400 dark:text-gray-500">views</span>
        </div>
    </div>

    <div class="flex-1 flex flex-col min-w-0">
        <h2 class="font-semibold text-gray-900 dark:text-gray-100 text-lg leading-snug group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors mb-2">
            {{ vraag.titel }}
        </h2>
        <span class="text-gray-500 dark:text-gray-400 text-sm line-clamp-2 flex-1 mb-3">{{ vraag.beschrijving }}</span>
        <div class="flex flex-wrap gap-2">
            {% for tag in vraag.tags %}
                <span class="bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 border border-indigo-200 dark:border-indigo-700 rounded-full py-0.5 px-3 text-xs font-medium">{{ tag.naam }}</span>
            {% endfor %}
        </div>
    </div>

    <div class="flex flex-row items-center justify-between sm:flex-col sm:items-end sm:justify-between gap-2 shrink-0">
        {% if vraag.status == 'Open' %}
        <span class="inline-flex items-center gap-1.5 bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-400 border border-green-200 dark:border-green-700 rounded-full py-0.5 px-3 text-xs font-semibold whitespace-nowrap">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500 inline-block"></span>Open
        </span>
        {% else %}
        <span class="inline-flex items-center gap-1.5 bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-700 rounded-full py-0.5 px-3 text-xs font-semibold whitespace-nowrap">
            <span class="w-1.5 h-1.5 rounded-full bg-red-500 inline-block"></span>Closed
        </span>
        {% endif %}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-300 dark:text-gray-600 group-hover:text-indigo-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
    </div>

</a>
