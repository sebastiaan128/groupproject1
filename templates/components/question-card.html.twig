<a href="{{ path('anwser-question', { id: vraag.id }) }}"
    class="border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 rounded-2xl p-4 mb-3 flex flex-col sm:flex-row gap-4 shadow-sm hover:shadow-md transition-shadow duration-200">


    <div class="flex sm:flex-col gap-2 sm:gap-3 sm:w-24 shrink-0">
        <div
            class="bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 border border-blue-300 dark:border-blue-700 rounded-xl py-2 px-3 flex flex-col items-center text-sm font-semibold w-full">
            <span class="text-xs font-normal opacity-70">Votes</span>
            <span>{{ vraag.upvotes }}</span>
        </div>
        <div
            class="bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300 border border-green-300 dark:border-green-700 rounded-xl py-2 px-3 flex flex-col items-center text-sm font-semibold w-full">
            <span class="text-xs font-normal opacity-70">Answers</span>
            <span>{{ vraag.antwoorden|length }}</span>
        </div>
        <div
            class="bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300 border border-purple-300 dark:border-purple-700 rounded-xl py-2 px-3 flex flex-col items-center text-sm font-semibold w-full">
            <span class="text-xs font-normal opacity-70">Views</span>
            <span>{{ vraag.views }}</span>
        </div>
    </div>

    <div class="flex-1 flex flex-col justify-between gap-3 min-w-0">
        <h2 class="font-semibold text-gray-900 dark:text-gray-100 text-lg leading-snug">
            {{ vraag.titel }}
        </h2>
        <span>{{ vraag.beschrijving }}</span>
        <div class="flex flex-wrap gap-2">
            {% for tag in vraag.tags %}
                <span
                    class="bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 rounded-lg py-0.5 px-2 text-sm">{{ tag.naam }}</span>
            {% endfor %}
        </div>
    </div>

    {# Status badge #}

    {% if vraag.status == 'Open' %}
    <span
        class="bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300 border border-green-300 dark:border-green-700 rounded-xl py-1 px-3 text-sm font-semibold whitespace-nowrap h-8">
            Open
        </span>
    {% else%}
    <span
        class="bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-300 border border-red-300 dark:border-red-700 rounded-xl py-1 px-3 text-sm font-semibold whitespace-nowrap h-8">
            Closed
        </span>
    {% endif %}
</a>
