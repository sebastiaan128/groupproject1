<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}TribeChat{% endblock %}</title>
        <link rel="icon" type="image/png" id="favicon" href="/assets/logo/favicon.png">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Ubuntu:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="/css/app.css">
        {% block stylesheets %}{% endblock %}
        <script>
            var _isDark = localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches);
            if (_isDark) {
                document.documentElement.classList.add('dark');
                document.getElementById('favicon').href = '/assets/logo/favicon_Light.png';
            } else {
                document.getElementById('favicon').href = '/assets/logo/favicon_Dark.png';
            }
        </script>
    </head>
    <body class="min-h-screen bg-gray-50 dark:bg-gray-900 dark:text-gray-100 transition-colors duration-300">
        <canvas id="bg-beams" class="bg-beams-canvas" aria-hidden="true"></canvas>

        {% block navbar %}
            {% include 'components/navbar.html.twig' %}
        {% endblock %}

        <main class="flex-grow-1 relative z-10">
            {% block body %}{% endblock %}
        </main>

{#        {% block footer %}#}
{#            {% include 'components/footer.html.twig' %}#}
{#        {% endblock %}#}

        {% block javascripts %}{% endblock %}
        <script src="/js/background-beams.js"></script>
        <script>
            (function () {
                var btn = document.getElementById('theme-toggle');
                var iconSun = document.getElementById('icon-sun');
                var iconMoon = document.getElementById('icon-moon');

                var favicon = document.getElementById('favicon');

                function applyTheme(isDark) {
                    if (isDark) {
                        document.documentElement.classList.add('dark');
                        iconSun.classList.remove('hidden');
                        iconMoon.classList.add('hidden');
                        if (favicon) favicon.href = '/assets/logo/favicon_Light.png';
                    } else {
                        document.documentElement.classList.remove('dark');
                        iconSun.classList.add('hidden');
                        iconMoon.classList.remove('hidden');
                        if (favicon) favicon.href = '/assets/logo/favicon_Dark.png';
                    }
                }

                if (btn) {
                    applyTheme(document.documentElement.classList.contains('dark'));
                    btn.addEventListener('click', function () {
                        var isDark = document.documentElement.classList.contains('dark');
                        localStorage.setItem('theme', isDark ? 'light' : 'dark');
                        applyTheme(!isDark);
                    });
                }
            })();
        </script>
    </body>
</html>
