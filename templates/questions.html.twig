{% extends 'base.html.twig' %}

{% block title %}Questions{% endblock %}

{% block body %}
<div class="w-full flex min-h-screen">

    <div class="w-[22%] shrink-0 flex flex-col gap-4 p-4">
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl p-4 flex flex-col gap-4 shadow-sm">

            <h2 class="text-sm font-bold text-gray-800 dark:text-gray-100 uppercase tracking-wide">Filter</h2>

            <div class="flex flex-col gap-1">
                <label class="text-xs font-medium text-gray-500 dark:text-gray-400">Search</label>
                <input type="text" id="search-input" value="{{ search }}"
                       placeholder="Search questions..."
                       class="border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-gray-100 rounded-xl px-3 py-2 w-full text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 placeholder-gray-400 dark:placeholder-gray-500">
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xs font-medium text-gray-500 dark:text-gray-400">Tags</label>
                <div class="flex flex-wrap gap-1.5">
                    {% for tag in tags|slice(0, 15) %}
                        <button data-tag="{{ tag.naam }}" onclick="selectTag({{ tag.naam|json_encode }})"
                                class="tag-btn text-xs font-medium px-2.5 py-1 rounded-full border border-gray-200 dark:border-gray-600 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:border-indigo-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all">
                            {{ tag.naam }}
                        </button>
                    {% endfor %}
                </div>
            </div>

            <button id="clear-filter" class="text-xs text-gray-400 dark:text-gray-500 hover:text-red-500 dark:hover:text-red-400 transition-colors text-left">
                ✕ Clear filter
            </button>

        </div>
    </div>

    <div class="w-[78%] flex flex-col gap-4 p-4">

        <div class="flex items-center justify-between">
            <div class="flex gap-3 flex-wrap" id="filter-buttons">
                <button onclick="setFilter('all')" data-filter="all"
                   class="filter-btn py-2 px-4 border rounded-xl font-semibold {{ filter == 'all' ? 'bg-blue-700 text-white border-blue-700' : 'bg-white hover:bg-gray-100 text-gray-600 border-gray-300' }}">
                    Questions
                </button>
                <button onclick="setFilter('open')" data-filter="open"
                   class="filter-btn py-2 px-4 border rounded-xl font-semibold {{ filter == 'open' ? 'bg-blue-700 text-white border-blue-700' : 'bg-white hover:bg-gray-100 text-gray-600 border-gray-300' }}">
                    Open
                </button>
                <button onclick="setFilter('closed')" data-filter="closed"
                   class="filter-btn py-2 px-4 border rounded-xl font-semibold {{ filter == 'closed' ? 'bg-blue-700 text-white border-blue-700' : 'bg-white hover:bg-gray-100 text-gray-600 border-gray-300' }}">
                    Closed
                </button>
                <button onclick="setFilter('my')" data-filter="my"
                   class="filter-btn py-2 px-4 border rounded-xl font-semibold {{ filter == 'my' ? 'bg-blue-700 text-white border-blue-700' : 'bg-white hover:bg-gray-100 text-gray-600 border-gray-300' }}">
                    My Questions
                </button>
            </div>
            {% if not is_guest %}
            <a href="{{ path('create-question') }}"
               class="bg-blue-700 text-white py-2 px-4 rounded-xl inline-block text-center">
                + New Question
            </a>
            {% endif %}
        </div>

        <div class="w-full bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 px-4 py-3 shadow-sm">
            <h3 id="vragen-count" class="text-sm text-gray-600 dark:text-gray-400 font-medium">{{ vragen|length }} Questions Found</h3>
        </div>

        <div id="vragen-container">
            {% for vraag in vragen %}
                {% include 'components/question-card.html.twig' with { vraag: vraag } %}
            {% endfor %}
        </div>

        <p id="no-results" class="hidden text-center text-gray-400 dark:text-gray-500 py-10">No questions found.</p>

    </div>
</div>

<script>
(function () {
    let currentFilter = '{{ filter }}';
    let selectedTag = null;
    let searchTimeout = null;

    const container  = document.getElementById('vragen-container');
    const countEl    = document.getElementById('vragen-count');
    const noResults  = document.getElementById('no-results');
    const searchInput = document.getElementById('search-input');

    function buildCard(v) {
        const tags = v.tags.map(t =>
            `<span class="bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 rounded-lg py-0.5 px-2 text-sm">${t}</span>`
        ).join('');
        const status = v.status === 'Open'
            ? `<span class="bg-green-100 text-green-700 border border-green-300 rounded-xl py-1 px-3 text-sm font-semibold whitespace-nowrap h-8">Open</span>`
            : `<span class="bg-red-100 text-red-700 border border-red-300 rounded-xl py-1 px-3 text-sm font-semibold whitespace-nowrap h-8">Closed</span>`;

        return `<a href="/anwser-question/${v.id}"
            class="border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 rounded-2xl p-4 mb-3 flex flex-col sm:flex-row gap-4 shadow-sm hover:shadow-md transition-shadow duration-200">
            <div class="flex sm:flex-col gap-2 sm:gap-3 sm:w-24 shrink-0">
                <div class="bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 border border-blue-300 dark:border-blue-700 rounded-xl py-2 px-3 flex flex-col items-center text-sm font-semibold w-full">
                    <span class="text-xs font-normal opacity-70">Votes</span><span>${v.upvotes}</span>
                </div>
                <div class="bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300 border border-green-300 dark:border-green-700 rounded-xl py-2 px-3 flex flex-col items-center text-sm font-semibold w-full">
                    <span class="text-xs font-normal opacity-70">Answers</span><span>${v.antwoorden}</span>
                </div>
                <div class="bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300 border border-purple-300 dark:border-purple-700 rounded-xl py-2 px-3 flex flex-col items-center text-sm font-semibold w-full">
                    <span class="text-xs font-normal opacity-70">Views</span><span>${v.views}</span>
                </div>
            </div>
            <div class="flex-1 flex flex-col justify-between gap-3 min-w-0">
                <h2 class="font-semibold text-gray-900 dark:text-gray-100 text-lg leading-snug">${v.titel}</h2>
                <span class="text-gray-600 dark:text-gray-400 text-sm">${v.beschrijving}</span>
                <div class="flex flex-wrap gap-2">${tags}</div>
            </div>
            ${status}
        </a>`;
    }

    function load() {
        const search = searchInput.value.trim();
        const params = new URLSearchParams({ filter: currentFilter, search });
        if (selectedTag) params.set('tag', selectedTag);

        fetch('/questions/load?' + params)
            .then(r => r.json())
            .then(data => {
                container.innerHTML = data.vragen.map(buildCard).join('');
                countEl.textContent = data.total + ' Questions Found';
                noResults.classList.toggle('hidden', data.total > 0);
            });
    }

    function setFilter(filter) {
        currentFilter = filter;
        document.querySelectorAll('.filter-btn').forEach(btn => {
            const active = btn.dataset.filter === filter;
            btn.classList.toggle('bg-blue-700', active);
            btn.classList.toggle('text-white', active);
            btn.classList.toggle('border-blue-700', active);
            btn.classList.toggle('bg-white', !active);
            btn.classList.toggle('text-gray-600', !active);
            btn.classList.toggle('border-gray-300', !active);
        });
        load();
    }

    window.selectTag = function (tagNaam) {
        if (selectedTag === tagNaam) {
            selectedTag = null;
        } else {
            selectedTag = tagNaam;
        }
        document.querySelectorAll('button[data-tag]').forEach(btn => {
            const active = btn.getAttribute('data-tag') === selectedTag;
            btn.classList.toggle('bg-indigo-500', active);
            btn.classList.toggle('text-white', active);
            btn.classList.toggle('border-indigo-500', active);
            btn.classList.toggle('bg-gray-100', !active);
            btn.classList.toggle('text-gray-600', !active);
            btn.classList.toggle('border-gray-200', !active);
        });
        load();
    };

    document.getElementById('clear-filter').addEventListener('click', function () {
        selectedTag = null;
        searchInput.value = '';
        document.querySelectorAll('button[data-tag]').forEach(btn => {
            btn.classList.remove('bg-indigo-500', 'text-white', 'border-indigo-500');
            btn.classList.add('bg-gray-100', 'text-gray-600', 'border-gray-200');
        });
        load();
    });

    window.setFilter = setFilter;

    searchInput.addEventListener('input', function () {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(load, 300);
    });
})();
</script>
{% endblock %}
