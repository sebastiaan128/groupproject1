{% extends 'base.html.twig' %}

{% block title %}Network{% endblock %}

{% block body %}
<div class="w-full flex bg-gray-100 dark:bg-gray-900 min-h-screen">

    <div class="w-[20%] flex flex-col gap-2 p-4 bg-white dark:bg-gray-800 shadow text-center">
        <h2 class="font-bold text-gray-800 dark:text-gray-100">Filter</h2>
        <div class="flex flex-col gap-1 text-left">
            <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Search Name</label>
            <input type="text" placeholder="Name..." class="border border-gray-300 dark:border-gray-600 bg-gray-100 dark:bg-gray-700 text-gray-900 dark:text-gray-100 rounded-xl p-2 w-full text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
        </div>
        <div class="flex flex-col gap-2 text-left mt-2">
            <h2 class="text-sm font-medium text-gray-700 dark:text-gray-300">Popular Tags</h2>
            <div class="flex flex-col gap-1">
                {% for tag in tags|default([]) %}
                    <span class="bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300 rounded-lg px-2 py-1 text-xs">{{ tag.naam }}</span>
                {% endfor %}
            </div>
        </div>
        <button class="mt-4 text-sm text-gray-500 dark:text-gray-400 hover:text-red-500 dark:hover:text-red-400 transition-colors">
            Clear filter
        </button>
    </div>

    <div class="w-[80%] flex flex-col gap-4 p-4">

        <div class="w-full bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 px-4 py-3 shadow-sm">
            <h3 class="text-sm text-gray-600 dark:text-gray-400 font-medium">{{ profielen|default([])|length }} Students Found</h3>
        </div>

        <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            {% for profiel in profielen|default([]) %}
                <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 hover:border-indigo-300 dark:hover:border-indigo-500 hover:shadow-lg transition-all p-4 flex flex-col gap-3">
                    <div class="flex items-center gap-3">
                        <div class="bg-gray-200 dark:bg-gray-700 w-12 h-12 rounded-full flex items-center justify-center text-gray-600 dark:text-gray-300 font-bold text-lg shrink-0">
                            {{ profiel.name|first|upper }}
                        </div>
                        <div class="text-left min-w-0">
                            <div class="font-semibold text-gray-900 dark:text-gray-100 truncate">{{ profiel.name }}</div>
                            <div class="text-xs text-gray-500 dark:text-gray-400 truncate">{{ profiel.email }}</div>
                        </div>
                    </div>
                    <p class="text-sm text-gray-600 dark:text-gray-400 text-left">{{ profiel.bio }}</p>
                    {% if profiel.tags is not empty %}
                        <div class="flex flex-wrap gap-1">
                            {% for tag in profiel.tags %}
                                <span class="bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 rounded-lg px-2 py-0.5 text-xs">{{ tag.naam }}</span>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>

    </div>
</div>
{% endblock %}
