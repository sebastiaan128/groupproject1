{% extends 'base.html.twig' %}

{% block title %}Network{% endblock %}

{% block body %}
<div class="w-full flex flex-col lg:flex-row min-h-screen">

    <div class="lg:w-[22%] lg:shrink-0 flex flex-col gap-4 p-4">

        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">

            <div class="px-4 pt-4">
                <h2 class="text-sm font-bold text-gray-800 dark:text-gray-100 uppercase tracking-wide mb-3">Filter</h2>
                <div class="flex flex-col gap-1 mb-3">
                    <label class="text-xs font-medium text-gray-500 dark:text-gray-400">Search</label>
                    <div class="relative">
                        <svg id="search-icon" xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35"/>
                        </svg>
                        <svg id="search-spinner" class="hidden absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-indigo-500 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
                        </svg>
                        <input type="text" id="search-name" placeholder="Search by name..." class="border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-gray-100 rounded-xl pl-9 pr-8 py-2 w-full text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 placeholder-gray-400 dark:placeholder-gray-500">
                        <button id="search-clear" class="hidden absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>

            <button id="filter-toggle" class="lg:hidden w-full flex items-center justify-between px-4 py-2 text-xs font-medium text-gray-500 dark:text-gray-400 border-t border-gray-100 dark:border-gray-700">
                Filter by tag
                <svg id="filter-chevron" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>
            </button>

            <div id="filter-panel" class="hidden lg:block px-4 pb-4">
                <label class="hidden lg:block text-xs font-medium text-gray-500 dark:text-gray-400 mb-2">Tags</label>
                <div class="flex flex-wrap gap-1.5 pt-2 lg:pt-0">
                    {% for tag in tags|slice(0, 15) %}
                        <button data-tag="{{ tag.naam }}" onclick="selectTag({{ tag.naam | json_encode }})"
                                class="tag-btn text-xs font-medium px-2.5 py-1 rounded-full border border-gray-200 dark:border-gray-600 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:border-indigo-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all">
                            {{ tag.naam }}
                        </button>
                    {% endfor %}
                </div>
                <button id="clear-filter" class="mt-3 text-xs text-gray-400 dark:text-gray-500 hover:text-red-500 dark:hover:text-red-400 transition-colors text-left">
                    ✕ Clear filter
                </button>
            </div>

        </div>
    </div>

    <div class="flex-1 flex flex-col gap-4 p-4">

        <div class="w-full bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 px-4 py-3 shadow-sm">
            <h3 id="profielen-count" class="text-sm text-gray-600 dark:text-gray-400 font-medium">{{ profielen|default([])|length }} Students Found</h3>
        </div>

        <div id="profielen-container" class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3"></div>

        <div id="spinner" class="flex justify-center py-6 hidden">
            <div class="w-6 h-6 border-2 border-indigo-500 border-t-transparent rounded-full animate-spin"></div>
        </div>
        <div id="sentinel" class="h-4"></div>

        <p id="no-results" class="hidden text-center text-gray-400 dark:text-gray-500 py-10">No students found.</p>

    </div>
</div>

<script>
(function () {
    let page = 1;
    let loading = false;
    let hasMore = true;
    let selectedTag = null;
    let currentAbort = null;

    const container     = document.getElementById('profielen-container');
    const sentinel      = document.getElementById('sentinel');
    const spinner       = document.getElementById('spinner');
    const countEl       = document.getElementById('profielen-count');
    const noResults     = document.getElementById('no-results');
    const searchInput   = document.getElementById('search-name');
    const searchIcon    = document.getElementById('search-icon');
    const searchSpinner = document.getElementById('search-spinner');
    const searchClear   = document.getElementById('search-clear');
    let isReset = false;

    function updateClearBtn() {
        searchClear.classList.toggle('hidden', searchInput.value === '');
    }

    searchClear.addEventListener('click', function() {
        searchInput.value = '';
        updateClearBtn();
        reset();
    });

    function setSearchState(loading) {
        searchIcon.classList.toggle('hidden', loading);
        searchSpinner.classList.toggle('hidden', !loading);
    }

    function buildCard(p) {
        const tagsHtml = p.tags.length
            ? '<div class="flex flex-wrap gap-1">' +
              p.tags.map(t => `<span class="bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 rounded-lg px-2 py-0.5 text-xs">${t}</span>`).join('') +
              '</div>'
            : '';
        return `<div class="profiel-card bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 shadow-sm p-4 flex flex-col gap-3">
            <div class="flex items-center gap-3">
                <div class="bg-gray-200 dark:bg-gray-700 w-12 h-12 rounded-full flex items-center justify-center text-gray-600 dark:text-gray-300 font-bold text-lg shrink-0">${p.name.charAt(0).toUpperCase()}</div>
                <div class="text-left min-w-0">
                    <div class="font-semibold text-gray-900 dark:text-gray-100 truncate">${p.name}</div>
                    <div class="text-xs text-gray-500 dark:text-gray-400 truncate">${p.email}</div>
                </div>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400 text-left">${p.bio || ''}</p>
            ${tagsHtml}
        </div>`;
    }

    function loadMore() {
        if (loading || !hasMore) return;
        loading = true;

        if (currentAbort) currentAbort.abort();
        currentAbort = new AbortController();

        if (isReset) setSearchState(true);
        else spinner.classList.remove('hidden');

        const params = new URLSearchParams({ page, search: searchInput.value.trim() });
        if (selectedTag) params.set('tag', selectedTag);

        fetch('/network/load?' + params, { signal: currentAbort.signal })
            .then(r => r.json())
            .then(data => {
                if (isReset) {
                    container.style.opacity = '0';
                    container.innerHTML = '';
                    requestAnimationFrame(function() { container.style.opacity = '1'; container.style.transition = 'opacity 0.15s ease'; });
                    isReset = false;
                }
                data.profielen.forEach(p => container.insertAdjacentHTML('beforeend', buildCard(p)));
                countEl.textContent = data.total + ' Students Found';
                hasMore = data.hasMore;
                noResults.classList.toggle('hidden', data.total > 0);
                sentinel.classList.toggle('hidden', !hasMore);
                page++;
            })
            .catch(function() {})
            .finally(() => {
                loading = false;
                setSearchState(false);
                spinner.classList.add('hidden');
                if (hasMore && sentinel.getBoundingClientRect().top <= window.innerHeight) {
                    loadMore();
                }
            });
    }

    function reset() {
        if (currentAbort) currentAbort.abort();
        loading = false;
        isReset = true;
        page = 1;
        hasMore = true;
        loadMore();
    }

    const observer = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) loadMore();
    }, { rootMargin: '400px' });
    observer.observe(sentinel);

    ['scroll', 'touchmove'].forEach(function (evt) {
        window.addEventListener(evt, function () {
            if (!loading && hasMore && sentinel.getBoundingClientRect().top <= window.innerHeight + 400) {
                loadMore();
            }
        }, { passive: true });
    });

    searchInput.addEventListener('input', function () {
        updateClearBtn();
        selectedTag = null;
        document.querySelectorAll('button[data-tag]').forEach(function(btn) {
            btn.className = TAG_OFF;
        });
        reset();
    });

    var TAG_OFF = 'tag-btn text-xs font-medium px-2.5 py-1 rounded-full border border-gray-200 dark:border-gray-600 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:border-indigo-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all';
    var TAG_ON  = 'tag-btn text-xs font-medium px-2.5 py-1 rounded-full border border-indigo-500 bg-indigo-500 text-white transition-all';

    window.selectTag = function (tagNaam) {
        selectedTag = selectedTag === tagNaam ? null : tagNaam;
        document.querySelectorAll('button[data-tag]').forEach(function(btn) {
            btn.className = btn.getAttribute('data-tag') === selectedTag ? TAG_ON : TAG_OFF;
        });
        reset();
    };

    document.getElementById('clear-filter').addEventListener('click', function () {
        selectedTag = null;
        searchInput.value = '';
        updateClearBtn();
        document.querySelectorAll('button[data-tag]').forEach(function(btn) {
            btn.className = TAG_OFF;
        });
        reset();
    });

    const filterToggle  = document.getElementById('filter-toggle');
    const filterPanel   = document.getElementById('filter-panel');
    const filterChevron = document.getElementById('filter-chevron');
    if (filterToggle) {
        filterToggle.addEventListener('click', function () {
            const isHidden = filterPanel.classList.toggle('hidden');
            filterChevron.style.transform = isHidden ? '' : 'rotate(180deg)';
        });
    }

    updateClearBtn();
    loadMore();
})();
</script>

{% endblock %}
