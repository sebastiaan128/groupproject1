{% extends 'base.html.twig' %}

{% block title %}Profile{% endblock %}

{% block body %}
<div class="main">
    <h1>My Profile</h1>

    <div class="container">
        <div class="upper">
            <div><img src="{{ asset('images/istockphoto-1495088043-612x612.jpg') }}" alt="profile picture"></div>
            <div class="fields-wrapper">
                <div class="fields">
                    <div class="field">
                        <h3>Name</h3>
                        <input type="text">
                    </div>
                    <div class="field">
                        <h3>E-mail</h3>
                        <input type="text">
                    </div>
                </div>
                <div class="fields">
                    <div class="field">
                        <h3>Study</h3>
                        <input type="text">
                    </div>
                    <div class="field">
                        <h3>Year</h3>
                        <input type="text">
                    </div>
                </div>
            </div>
        </div>
        <div class="field">
            <h3>Bio</h3>
            <input type="text">
        </div>
    </div>
    <div class="container-two">
        <div class="edit-header">
            <div class="field">
                <h2>Knowledge Tags</h2>
            </div>
            <h4 class="edit-btn">Edit</h4>
        </div>
        <div>
            1234
        </div>
    </div>
    <div class="save-cancel">
        <div class="save-btn">
            <h3>Save</h3>
        </div>
        <div class="cancel-btn">
            <h3>Cancel</h3>
        </div>
    </div>
</div>
{% endblock %}
