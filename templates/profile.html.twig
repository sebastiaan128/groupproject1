{% extends 'base.html.twig' %}

{% block title %}My Profile{% endblock %}

{% block body %}

{# SQL injection caught popup #}
<div id="sqli-overlay" class="hidden fixed inset-0 z-[999] flex items-center justify-center bg-black/70 backdrop-blur-sm">
    <div class="relative bg-gray-900 border border-red-500 rounded-2xl shadow-2xl max-w-sm w-full mx-4 p-8 flex flex-col items-center gap-4 text-center">
        <div class="w-16 h-16 rounded-full bg-red-500/20 border-2 border-red-500 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
            </svg>
        </div>
        <h2 class="text-2xl font-black text-white tracking-tight">Nice try. 🖕</h2>
        <p class="text-gray-300 text-sm leading-relaxed">We see what you're doing.<br>SQL injection doesn't work here.<br><span class="text-red-400 font-semibold">Go touch some grass.</span></p>
        <button onclick="document.getElementById('sqli-overlay').classList.add('hidden')"
            class="mt-2 px-6 py-2 bg-red-600 hover:bg-red-700 text-white rounded-xl font-bold text-sm transition-colors">
            Fine, I'll behave
        </button>
    </div>
</div>

{{ form_start(form, {'attr': {'id': 'ProfileType'}}) }}
<div class="main w-full sm:w-auto px-4 sm:px-0 items-center">
    <h1>My Profile</h1>
    <div class="container dark:border-gray-700 bg-white dark:bg-gray-800">
            <div>
                <a href="{{ path('profile') }}"
                    class="hidden sm:flex avatar-glass w-17.5 h-17.5 rounded-full items-center justify-center">
                    <img id="desktop-avatar" src="/assets/logo/profile.png" alt="User Avatar"
                        class="w-full h-full rounded-full object-cover">
                </a>
            </div>
            <div class="fields-wrapper">
                <div class="edit-btn">
                    <h4>Edit</h4>
                </div>
                <div class="fields-col">
                    <div class="field">
                        <h3>Name</h3>
                        <div class="border rounded-lg border-gray-300 resize-none mt-1">
                            {{ form_widget(form.name, {'attr': {'class': 'profile-input', 'disabled': true}}) }}
                        </div>
                        {% if form.name.vars.errors|length > 0 %}
                        <p class="text-red-500 text-sm mt-1">{{ form_errors(form.name) }}</p>
                        {% endif %}
                    </div>

                    <div class="field">
                        <h3>Email</h3>
                        <div class="border rounded-lg border-gray-300 resize-none mt-1">
                            {{ form_widget(form.email, {'attr': {'class': 'profile-input', 'disabled': true}}) }}
                        </div>
                        {% if form.email.vars.errors|length > 0 %}
                        <p class="text-red-500 text-sm mt-1">{{ form_errors(form.email) }}</p>
                        {% endif %}
                    </div>
                    <div class="upper">
                        <div class="field">
                            <h3>Study</h3>
                            <div class="border rounded-lg border-gray-300 resize-none mt-1">
                                {{ form_widget(form.studie, {'attr': {'class': 'profile-input', 'disabled': true}}) }}
                            </div>
                        </div>

                        <div class="field">
                            <h3>Year</h3>
                            <div class="border rounded-lg border-gray-300 resize-none mt-1">
                                {{ form_widget(form.jaar, {'attr': {'class': 'profile-input', 'disabled': true}}) }}
                            </div>
                            {% if form.jaar.vars.errors|length > 0 %}
                            <p class="text-red-500 text-sm mt-1">{{ form_errors(form.jaar) }}</p>
                            {% endif %}
                        </div>
                    </div>
                    <div class="field">
                        <h3>Bio</h3>
                        <div class="border rounded-lg border-gray-300 resize-none mt-1">
                            {{ form_widget(form.bio, {'attr': {'class': 'profile-input', 'disabled': true}}) }}
                        </div>
                        {% if form.bio.vars.errors|length > 0 %}
                        <p class="text-red-500 text-sm mt-1">{{ form_errors(form.bio) }}</p>
                        {% endif %}
                    </div>

                    <div class="container-two dark:border-gray-700 bg-white dark:bg-gray-800">
                        <h2>Knowledge Tags</h2>

                        <div class="flex flex-wrap gap-2 mb-3" id="tags-display">
                            {% for tag in profiel.tags %}
                            <span
                                class="bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 rounded-lg py-0.5 px-2 text-sm">
                                {{ tag.naam }}
                            </span>
                            {% else %}
                            <span class="text-gray-400 text-sm">Geen tags geselecteerd</span>
                            {% endfor %}
                        </div>

                        <div id="tags-edit" class="hidden">
                            <div class="tags-wrapper">
                                {{ form_widget(form.tags) }}
                            </div>
                        </div>
                    </div>
                </div>
                <div class="save-cancel">
                    <button type="submit" class="btn-save">
                        <h3>Save</h3>
                    </button>
                    <a href="{{ path('profile') }}" class="btn-cancel dark:border-gray-700 bg-white dark:bg-gray-800">
                        <h3>Cancel</h3>
                    </a>
                </div>
            </div>
            {{ form_end(form) }}
            <script>
                document.querySelector('.edit-btn').addEventListener('click', function () {
                    const inputs = document.querySelectorAll('.profile-input');
                    const isDisabled = inputs[0].disabled;
                    const tagsEdit = document.getElementById('tags-edit');
                    const tagsDisplay = document.getElementById('tags-display');

                    inputs.forEach(input => {
                        input.disabled = !isDisabled;
                        const wrapper = input.closest('div');
                        if (isDisabled) {
                            wrapper.classList.add('input-active');
                            wrapper.classList.remove('border-gray-300');
                            wrapper.classList.add('bg-gray-50', 'dark:bg-gray-700');
                        } else {
                            wrapper.classList.remove('input-active');
                            wrapper.classList.add('border-gray-300');
                            wrapper.classList.remove('bg-gray-50', 'dark:bg-gray-700');
                        }
                    });

                    if (isDisabled) {
                        tagsEdit.classList.remove('hidden');
                        tagsDisplay.classList.add('hidden');
                    } else {
                        tagsEdit.classList.add('hidden');
                        tagsDisplay.classList.remove('hidden');
                    }

                    const hasErrors = document.querySelectorAll('.text-red-500').length > 0;
                    if (hasErrors) {
                        const inputs = document.querySelectorAll('.profile-input');
                        const tagsEdit = document.getElementById('tags-edit');
                        const tagsDisplay = document.getElementById('tags-display');
                        const editBtn = document.querySelector('.edit-btn h4');

                        inputs.forEach(input => {
                            input.disabled = false;
                            const wrapper = input.closest('div');
                            wrapper.classList.add('input-active', 'bg-gray-50', 'dark:bg-gray-700');
                            wrapper.classList.remove('border-gray-300');
                        });

                        tagsEdit.classList.remove('hidden');
                        tagsDisplay.classList.add('hidden');
                        editBtn.textContent = 'Edit';
                    }

                    this.querySelector('h4').textContent = isDisabled ? 'Edit' : 'Edit';
                });

                {% if sql_attempt is defined and sql_attempt %}
                document.getElementById('sqli-overlay').classList.remove('hidden');
                {% endif %}

                var sqliPatterns = [
                    /('|--|;|\/\*|\*\/)/i,
                    /\b(select|insert|update|delete|drop|union|exec|execute|create|alter|truncate|cast|convert|declare)\b/i,
                    /\b(or|and)\s+[\w'"]+\s*=\s*[\w'"]+/i,
                    /xp_/i,
                    /0x[0-9a-f]+/i
                ];

                function hasSqli(val) {
                    return sqliPatterns.some(function(p) { return p.test(val); });
                }

                document.getElementById('ProfileType').addEventListener('submit', function(e) {
                    var inputs = this.querySelectorAll('input[type="text"], input[type="email"], textarea');
                    for (var i = 0; i < inputs.length; i++) {
                        if (hasSqli(inputs[i].value)) {
                            e.preventDefault();
                            document.getElementById('sqli-overlay').classList.remove('hidden');
                            return;
                        }
                    }
                });
            </script>
            {% endblock %}
