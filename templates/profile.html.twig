{% extends 'base.html.twig' %}

{% block title %}My Profile{% endblock %}

{% block body %}
<div class="main">
    <h1>My Profile</h1>
    <div class="container dark:border-gray-700 bg-white dark:bg-gray-800">
        <div class="upper">
            <div>
                <a href="{{ path('profile') }}"
                    class="hidden sm:flex avatar-glass w-17.5 h-17.5 rounded-full items-center justify-center text-sm font-semibold cursor-pointer transition-all text-gray-700 dark:text-gray-200">
                    <img id="desktop-avatar" src="/assets/logo/profile.png" alt="User Avatar"
                        class="w-full h-full rounded-full object-cover">
                </a>
            </div>
            <div class="fields-wrapper">
                <div class="fields-col">
                    <div class="field">
                        <h3>Name</h3>
                        <div class="border rounded-lg border-gray-300 resize-none mt-1">
                            <input type="text">
                        </div>
                    </div>
                    <div class="field ">
                        <h3>Email</h3>
                        <div class="border rounded-lg border-gray-300 resize-none mt-1">
                            <input type="text">
                        </div>
                    </div>
                </div>
                <div class="fields-row">
                    <div class="field">
                        <h3>Study</h3>
                        <div class="border rounded-lg border-gray-300 resize-none mt-1">
                            <input type="text">
                        </div>
                    </div>
                    <div class="field">
                        <h3>Year</h3>
                        <div class="border rounded-lg border-gray-300 resize-none mt-1">
                            <input type="text">
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="field">
            <h3>Bio</h3>
            <div class="border rounded-lg border-gray-300 resize-none mt-1">
                <input type="text">
            </div>
        </div>
    </div>
    <div class="container-two dark:border-gray-700 bg-white dark:bg-gray-800">
        <div class="edit-header">
            <div class="field">
                <h2>Knowledge Tags</h2>
            </div>
            <h4 class="edit-btn">Edit</h4>
        </div>
        <div class="flex flex-wrap gap-2">
            <span class="bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 rounded-lg py-0.5 px-2 text-sm">React</span>
            <span class="bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-300 rounded-lg py-0.5 px-2 text-sm">Javascript</span>
            <span class="bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300 rounded-lg py-0.5 px-2 text-sm">SQL</span>
        </div>
    </div>
    <div class="save-cancel">
        <div class="btn-save">
            <h3>Save</h3>
        </div>
        <div class="btn-cancel dark:border-gray-700 bg-white dark:bg-gray-800">
            <h3>Cancel</h3>
        </div>
    </div>
</div>
{% endblock %}