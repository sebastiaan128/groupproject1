{% extends 'base.html.twig' %}

{% block title %}New Question{% endblock %}

{% block body %}
<div class="flex mt-7">
    <div class="flex-1"></div>

    <div class="w-full max-w-4xl">
        <a href="{{ path('questions') }}"
           class="bg-white hover:bg-gray-100 text-gray-600 font-semibold py-2 px-4 border border-gray-300 rounded-xl flex items-center justify-center gap-2 text-center inline-flex">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                 stroke="currentColor"
                 class="size-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
            </svg>
            Questions
        </a>
        <h1 class="text-3xl mt-6 font-bold">New Question</h1>
        <div class="bg-blue-50 border border-blue-200 rounded-2xl p-4 mt-5">
            <span class="text-blue-900 font-bold ms-2">Tips for asking a good question:</span>
            <ul class=" text-gray-700 ms-2 mt-3">
                <li class="text-blue-800">
                    <span class="font-extrabold">•</span>
                    <span>Be specific and clear in your question</span></li>
                <li class="text-blue-800">
                    <span class="font-extrabold">•</span>
                    <span>Provide context and examples</span></li>
                <li class="text-blue-800">
                    <span class="font-extrabold">•</span>
                    <span>Use relevant tags</span></li>
                <li class="text-blue-800">
                    <span class="font-extrabold">•</span>
                    <span>Check whether the question has already been asked</span>
                </li>
            </ul>
        </div>
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm p-6 mt-7">
            <form action="/submit-question" method="POST">
            <div class="flex flex-col">
                <span>Title</span>
                <textarea
                    name="titel"
                    class="border rounded-lg border-gray-300 resize-none mt-1"
                    rows="2"
                ></textarea>
            </div>
            <div class="flex flex-col mt-4">
                <span>Description</span>
                <textarea
                    name="beschrijving"
                    class="border rounded-lg border-gray-300 resize-none mt-1"
                    rows="7"
                ></textarea></div>
                <div class="flex flex-col mt-4">
                    <div>
                        <span>Tags</span>
                    </div>
                    <div class="mt-3">
                        <span class="bg-blue-100 text-blue-700 rounded-lg p-1 px-2 me-1">Tag 1</span>
                        <span class="bg-yellow-100 text-yellow-700 rounded-lg p-1 px-2 me-1">Tag 2</span>
                        <span class="bg-green-100 text-green-700 rounded-lg p-1 px-2">Tag 3</span>
                    </div>
                </div>
            <div class="flex mt-6 mb-2">
                <button type="button" class="w-1/2 bg-white hover:bg-gray-100 text-gray-600 font-semibold py-2 px-4 border border-gray-300 rounded-xl me-4">Cancel</button>
                <button type="submit" class="w-1/2 px-4 py-2 bg-blue-500 text-white rounded-lg font-semibold">Send</button>
            </div>
        </form>
        </div>
    </div>
    <div class="flex-1"></div>
</div>
{% endblock %}
