{% extends 'base.html.twig' %}

{% block title %}New Question{% endblock %}

{% block body %}
<div class="flex mt-7">
    <div class="flex-1"></div>

    <div class="w-full max-w-4xl">
        <a href="{{ path('questions') }}"
           class="inline-flex items-center gap-2 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                 stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
            </svg>
            Back to Questions
        </a>
        <h1 class="text-3xl mt-6 font-bold">New Question</h1>
        <div class="bg-blue-50 border border-blue-200 rounded-2xl p-4 mt-5">
            <span class="text-blue-900 font-bold ms-2">Tips for asking a good question:</span>
            <ul class="text-gray-700 ms-2 mt-3">
                <li class="text-blue-800"><span class="font-extrabold">•</span> <span>Be specific and clear in your question</span></li>
                <li class="text-blue-800"><span class="font-extrabold">•</span> <span>Provide context and examples</span></li>
                <li class="text-blue-800"><span class="font-extrabold">•</span> <span>Use relevant tags</span></li>
                <li class="text-blue-800"><span class="font-extrabold">•</span> <span>Check whether the question has already been asked</span></li>
            </ul>
        </div>
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm p-6 mt-7">
            <form action="/submit-question" method="POST">
                <div class="flex flex-col">
                    <span class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title</span>
                    <textarea
                        name="titel"
                        class="border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-gray-100 rounded-xl px-3 py-2 resize-none text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
                        rows="2"
                    ></textarea>
                </div>
                <div class="flex flex-col mt-4">
                    <span class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</span>
                    <textarea
                        name="beschrijving"
                        class="border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-gray-100 rounded-xl px-3 py-2 resize-none text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
                        rows="7"
                    ></textarea>
                </div>
                <div class="flex flex-col mt-4">
                    <span class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Tags</span>
                    <div id="tag-container" class="flex flex-wrap gap-2">
                        {% for tag in tags %}
                            <button type="button"
                                data-id="{{ tag.id }}"
                                onclick="toggleTag(this)"
                                class="tag-btn text-xs font-medium px-2.5 py-1 rounded-full border border-gray-200 dark:border-gray-600 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:border-indigo-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all cursor-pointer"
                                data-selected="0">
                                {{ tag.naam }}
                            </button>
                        {% endfor %}
                    </div>
                    <div id="tag-inputs"></div>
                </div>
                <div class="flex mt-6 mb-2 gap-3">
                    <a href="{{ path('questions') }}" class="w-1/2 bg-white dark:bg-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 text-gray-600 dark:text-gray-300 font-semibold py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-xl text-center text-sm">Cancel</a>
                    <button type="submit" class="w-1/2 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-semibold text-sm transition-colors">Post Question</button>
                </div>
            </form>
        </div>
    </div>
    <div class="flex-1"></div>
</div>
{% endblock %}

{% block javascripts %}
<script>
var TAG_OFF = 'tag-btn text-xs font-medium px-2.5 py-1 rounded-full border border-gray-200 dark:border-gray-600 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:border-indigo-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all cursor-pointer';
var TAG_ON  = 'tag-btn text-xs font-medium px-2.5 py-1 rounded-full border border-indigo-500 bg-indigo-500 text-white transition-all cursor-pointer';

function toggleTag(btn) {
    var selected = btn.getAttribute('data-selected') === '1';
    var inputsDiv = document.getElementById('tag-inputs');
    var id = btn.getAttribute('data-id');

    if (selected) {
        btn.setAttribute('data-selected', '0');
        btn.className = TAG_OFF;
        var existing = inputsDiv.querySelector('input[value="' + id + '"]');
        if (existing) existing.remove();
    } else {
        btn.setAttribute('data-selected', '1');
        btn.className = TAG_ON;
        var input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'tags[]';
        input.value = id;
        inputsDiv.appendChild(input);
    }
}
</script>
{% endblock %}
